# Environment Variables

# Server
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://twynd_local:localdev123@localhost:5432/twynd_dev"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=com.twynd.app://oauth/google

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_REDIRECT_URI=com.twynd.app://oauth/facebook

# TikTok OAuth
TIKTOK_CLIENT_ID=
TIKTOK_REDIRECT_URI=com.twynd.app://oauth/tiktok

# Gemini API
GEMINI_API_KEY=

# Node Environment
NODE_ENV=development
