# Mobile App Environment Variables
# These must be prefixed with EXPO_PUBLIC_ to be accessible in the app

# Server API URL (without /api suffix - it will be added automatically)
EXPO_PUBLIC_API_URL=http://192.168.100.5:3000

# WebSocket URL for real-time chat
EXPO_PUBLIC_WS_URL=ws://192.168.100.5:8080

# Note: Replace 192.168.100.5 with your server's IP address or domain
# For local development on Android emulator, use: http://10.0.2.2:3000
# For local development on iOS simulator, use: http://localhost:3000
